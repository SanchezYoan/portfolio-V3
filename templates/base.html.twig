<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{% block title %}Portfolio{% endblock %} — YoanSAN</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}{% endblock %}
		{{ encore_entry_link_tags('app') }}
	</head>
	<body>
		<nav class="site-nav" id="siteNav">
			<a class="site-nav__brand" href="{{ url('home') }}">YoanSAN</a>

			<button class="site-nav__burger" id="navBurger" aria-label="Menu" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>

			<ul class="site-nav__links">
				<li>
					<a class="site-nav__link {{ app.current_route == 'about.show' ? 'site-nav__link--active' : '' }}"
					   href="{{ url('about.show') }}">À propos</a>
				</li>
				<li>
					<a class="site-nav__link {{ app.current_route starts with 'project.' ? 'site-nav__link--active' : '' }}"
					   href="{{ url('project.index') }}">Projets</a>
				</li>
				<li>
					<a class="site-nav__link {{ app.current_route == 'news.index' ? 'site-nav__link--active' : '' }}"
					   href="{{ url('news.index') }}">Actu</a>
				</li>
				<li>
					<a class="site-nav__link {{ app.current_route == 'contact' ? 'site-nav__link--active' : '' }}"
					   href="{{ url('contact') }}">Contact</a>
				</li>
			</ul>

			<ul class="site-nav__actions">
				{% if not is_granted('ROLE_USER') %}
					<li><a class="btn-nav btn-nav--ghost" href="{{ url('security.login') }}">Connexion</a></li>
					<li><a class="btn-nav btn-nav--primary" href="{{ url('security.register') }}">Inscription</a></li>
				{% endif %}
				{% if is_granted('ROLE_USER') %}
					<li>
						<a class="site-nav__link {{ app.current_route == 'profil.index' ? 'site-nav__link--active' : '' }}"
						   href="{{ url('profil.index') }}">{{ ux_icon('mdi:account-circle', {'width': '1.5rem', 'height': '1.5rem'}, {class: 'text-white'}) }}</a>
					</li>
					<li><a class="btn-nav btn-nav--ghost" href="{{ logout_path() }}">Déconnexion</a></li>
				{% endif %}
			</ul>
		</nav>

		<script>
			(function () {
				var burger = document.getElementById('navBurger');
				var nav    = document.getElementById('siteNav');
				burger.addEventListener('click', function () {
					var open = nav.classList.toggle('site-nav--open');
					burger.setAttribute('aria-expanded', open);
				});
				document.addEventListener('click', function (e) {
					if (!nav.contains(e.target)) {
						nav.classList.remove('site-nav--open');
						burger.setAttribute('aria-expanded', 'false');
					}
				});
			})();
		</script>

		<div class="flash-wrapper">
			{% include 'partials/flash.html.twig' %}
		</div>

		<main class="page-content">
			{% block body %}{% endblock %}
		</main>

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
	</body>
</html>
