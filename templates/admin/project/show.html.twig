{% extends 'admin/admin.html.twig' %}

{% block title %}{{ project.title }} - Administration{% endblock %}

{% block body %}
    <div id="vue-page"
         data-component="AdminProjectShow"
         data-props="{{ {'project': {
             'id': project.id,
             'title': project.title,
             'description': project.description,
             'results': project.results,
             'learnings': project.learnings,
             'githubUrl': project.githubUrl,
             'demoUrl': project.demoUrl
         }}|json_encode }}">
    </div>
{% endblock %}
