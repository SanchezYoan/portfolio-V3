{% extends 'base.html.twig' %}

{% block title %}{{ project.title }}{% endblock %}

{% block body %}
    <div id="vue-page"
         data-component="ProjectShow"
         data-props="{{ {'project': {
             'id': project.id,
             'title': project.title,
             'description': project.description,
             'results': project.results,
             'learnings': project.learnings,
             'githubUrl': project.githubUrl,
             'demoUrl': project.demoUrl,
             'thumbnailUrl': project.image ? '/images/projects/' ~ project.image : null,
             'images': project.images|map(img => {'id': img.id, 'url': '/images/projects/' ~ img.image})
         }}|json_encode }}">
    </div>
{% endblock %}
