{% extends 'base.html.twig' %}

{% block title %}Hello ProjectController!
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		{% for project in projects %}
			<div class="card mb-3">
				<div class="card-body">
					<h5 class="card-title">{{ project.title }}</h5>
					<p class="card-text">{{ project.description }}</p>
					<a href="{{ url('project.show', { 'id': project.id }) }}" class="btn btn-primary">Voir le projet</a>
				</div>
			</div>
		{% else %}
			<p>Aucun projet trouvé.</p>
		{% endfor %}
	</div>
{% endblock %}
