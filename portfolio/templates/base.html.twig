<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> {% block stylesheets %}{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<nav class="navbar bg-primary navbar-expand-lg" data-bs-theme="dark">
			<div class="container-fluid">
				<a class="navbar-brand" href="{{ url("home") }}">Monsite</a>
				<div class="">
					<ul class="navbar-nav">
						<li class="nav-item">
							<a class="nav-link {{ app.current_route == 'home' ? 'active' : '' }}" href="{{ url("home") }}">Acceuil</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{ app.current_route == 'profil' ? 'active' : '' }}" href="{{ url("profil.index") }}">Profil</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{ app.current_route starts with 'project.' ? 'active' : '' }}" href="{{ url("project.index") }}">Projets</a>
						</li>
					</div>
				</nav>
				{% block body %}{% endblock %}
			</body>
		</html>
	</body>
</html>
