{% extends 'admin/admin.html.twig' %}

{% block title %}Hello ProjectController!
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<a href="{{ url('admin.project.new') }}" class="btn btn-primary mb-3">Ajouter un projet</a>
		{% for project in projects %}
			<div class="card mb-3">
                <div class="card-header d-flex justify-content-between">
            	<h5 class="card-title">{{ project.title }}</h5>
                <div class="d-flex gap-2">
                <a href="{{ url('admin.project.show', { 'id': project.id }) }}" class="btn btn-primary">{{ ux_icon('mdi:eye', {class: 'w-20 h-20'}) }}</a>
                <a href="{{ url('admin.project.edit', { 'id': project.id }) }}" class="btn btn-success">{{ ux_icon('mdi:pencil', {class: 'w-20 h-20'}) }}</a>
                <form action="{{ path('admin.project.delete', {id: project.id}) }}" method="post">
                    <input type="hidden" name="_method" value="DELETE">
                    <button class="btn btn-danger" type="submit">
                        {{ ux_icon('mdi:delete', {class: 'w-20 h-20'}) }}
                    </button>
				</form>
                </div>
                </div>
    			<div class="card-body">
					<p class="card-text">{{ project.description }}</p>
				</div>
			</div>
		{% else %}
			<p>Aucun projet trouvé.</p>
		{% endfor %}
	</div>
{% endblock %}
